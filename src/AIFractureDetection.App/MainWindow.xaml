<Window x:Class="AIFractureDetection.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AIFractureDetection.App.ViewModels"
        xmlns:models="clr-namespace:AIFractureDetection.App.Models"
        mc:Ignorable="d"
        Title="AI Fracture Detection"
        Height="780" Width="1180"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="LabelText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ÜST BAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="8" Margin="0,0,12,0">
                        <TextBlock Text="AI" Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="AI Fracture Detection"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Yapay zekâ destekli kırık ve çıkık tespit uygulaması"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- API durumu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="API" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                             Width="250" Padding="8,6" FontSize="12"
                             Background="{DynamicResource SurfaceAltBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button Content="Kontrol Et"
                            Command="{Binding PingApiCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="🌓 Tema"
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>
        </Border>

        <!-- ANA İÇERİK -->
        <Grid Grid.Row="1" Margin="24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- SOL: dosya + önizleme -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Drop zone (dosya seçili değilse) -->
                    <Border x:Name="DropZone"
                            Grid.Row="0" Grid.RowSpan="3"
                            Visibility="{Binding HasFile, Converter={StaticResource InverseBoolToVis}}"
                            Background="{DynamicResource DropZoneBrush}"
                            BorderBrush="{DynamicResource DropZoneBorderBrush}"
                            BorderThickness="2" CornerRadius="12"
                            Padding="40" MinHeight="380">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDraggingOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DropZoneActiveBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource DropZoneActiveBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center"/>
                            <TextBlock Text="NIfTI dosyasını buraya sürükleyin"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource TitleTextStyle}"
                                       Margin="0,16,0,4"/>
                            <TextBlock Text="veya aşağıdaki butondan seçin. Desteklenen formatlar: .nii, .nii.gz"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource SubtitleTextStyle}"/>
                            <Button Content="Dosya Seç"
                                    Command="{Binding PickFileCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Dosya info + önizleme (dosya seçiliyse) -->
                    <Grid Grid.Row="0" Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedFileName}"
                                       Style="{StaticResource TitleTextStyle}" FontSize="16"/>
                            <TextBlock Text="{Binding SelectedFileSizeText}"
                                       Style="{StaticResource SubtitleTextStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Dosya Değiştir"
                                    Command="{Binding PickFileCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Content="Temizle"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,16,0,0"
                            Background="Black" CornerRadius="8"
                            Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}">
                        <Image Source="{Binding PreviewImage}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- Slice kontrol + oryantasyon -->
                    <Grid Grid.Row="2" Margin="0,16,0,0"
                          Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox SelectedIndex="0" Width="110" Padding="6"
                                  SelectionChanged="OrientationCombo_Changed"
                                  x:Name="OrientationCombo">
                            <ComboBoxItem Content="Axial"/>
                            <ComboBoxItem Content="Coronal"/>
                            <ComboBoxItem Content="Sagittal"/>
                        </ComboBox>
                        <Slider Grid.Column="1" Margin="12,0"
                                Minimum="0"
                                Maximum="{Binding MaxSlice}"
                                Value="{Binding CurrentSlice, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   MinWidth="70" TextAlignment="Right">
                            <Run Text="Kesit "/>
                            <Run Text="{Binding CurrentSlice}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding MaxSlice}"/>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <!-- SAĞ: analiz + sonuç -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Analiz" Style="{StaticResource TitleTextStyle}"/>
                        <TextBlock Text="Dosyanızı Python AI servisine gönderin."
                                   Style="{StaticResource SubtitleTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <Button Content="🔬 Analiz Et"
                                Command="{Binding AnalyzeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"/>

                        <ProgressBar Height="6" Margin="0,12,0,0"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding Progress}"
                                     Foreground="{DynamicResource PrimaryBrush}"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     BorderThickness="0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Sonuç -->
                    <ScrollViewer Grid.Row="2" Margin="0,16,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding Result, Converter={StaticResource NullToVis}}">
                        <StackPanel>
                            <Border Padding="14" CornerRadius="8"
                                    Background="{DynamicResource SurfaceAltBrush}">
                                <StackPanel>
                                    <TextBlock Text="GENEL DURUM" Style="{StaticResource LabelText}"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0">
                                        <Run Text="{Binding Result.Status, FallbackValue=-}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource SubtitleTextStyle}">
                                        <Run Text="Güven: "/>
                                        <Run Text="{Binding Result.OverallConfidence, StringFormat=P1}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding Result.InferenceTimeMs, StringFormat={}{0:F0} ms}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="BULGULAR" Style="{StaticResource LabelText}" Margin="0,18,0,8"/>

                            <ItemsControl ItemsSource="{Binding Result.Findings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:Finding}">
                                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="8"
                                                Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                                    <Border Grid.Column="1"
                                                            Background="{DynamicResource PrimaryBrush}"
                                                            CornerRadius="10" Padding="8,2">
                                                        <TextBlock Foreground="White" FontSize="11">
                                                            <Run Text="{Binding Confidence, StringFormat=P0}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Margin="0,4,0,0"
                                                           Style="{StaticResource SubtitleTextStyle}">
                                                    <Run Text="Tip: "/>
                                                    <Run Text="{Binding Type}"/>
                                                    <Run Text=" • Bölge: "/>
                                                    <Run Text="{Binding Region, FallbackValue=-}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- PDF Export -->
                    <Button Grid.Row="3"
                            Content="📄 PDF Rapor Oluştur"
                            Command="{Binding ExportReportCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,16,0,0"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ALT BAR -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="v0.1.0"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
